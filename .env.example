# ── Anthropic (必須) ──────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
MODEL_NAME=anthropic/claude-sonnet-4-6
TEMPERATURE=0.7
MAX_TOKENS=4096

# ── Alpaca Trading API ────────────────────────────────────────
# ペーパートレード: https://paper-api.alpaca.markets  ← デフォルト（安全）
# 本番トレード:    https://api.alpaca.markets          ← 実資金に注意！
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

# ── Telegram Bot ──────────────────────────────────────────────
# BotFather で作成: https://t.me/BotFather → /newbot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# 自分のチャットIDを取得: @userinfobot に話しかける
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Trading Monitor Settings ──────────────────────────────────
POLL_INTERVAL_SECONDS=60
MAX_WATCHLIST_SIZE=10
TRADING_DB_PATH=./trading/cache/trading.db

# ── Broker Selection ──────────────────────────────────────────
# "alpaca"（米国株・デフォルト）または "moomoo"（日本株・米国株対応）
BROKER=alpaca

# ── MooMoo OpenAPI ────────────────────────────────────────────
# MooMoo OpenD（ローカルデーモン）が必要: https://www.moomoo.com/ja/download/OpenAPI
# 1. MooMoo アプリ → 取引 → OpenAPI → OpenD をダウンロード・起動
# 2. 以下の認証情報を設定する
MOOMOO_HOST=127.0.0.1
MOOMOO_PORT=11111
# 取引環境: SIMULATE（模擬・デフォルト）または REAL（実取引・注意！）
MOOMOO_TRADE_ENV=SIMULATE
# 対象マーケット: US（米国株）または HK（香港株）
MOOMOO_MARKET=US

# ── X (Twitter) API ───────────────────────────────────────────
# X Developer Portal で取得: https://developer.twitter.com/en/portal/dashboard
# アカウント: @ELXSrDlKjj39240
# 必要な権限: "Read and Write" (投稿のため)
X_API_KEY=your_x_api_key_here
X_API_SECRET=your_x_api_secret_here
X_ACCESS_TOKEN=your_x_access_token_here
X_ACCESS_TOKEN_SECRET=your_x_access_token_secret_here
X_BEARER_TOKEN=your_x_bearer_token_here
X_ACCOUNT_HANDLE=ELXSrDlKjj39240

# ── Google AI (Nano Banana Pro 画像生成) ─────────────────────
# Google AI Studio で取得: https://aistudio.google.com/app/apikey
# モデル: gemini-3-pro-image-preview（画像生成）
GOOGLE_API_KEY=your_google_api_key_here

# ── 資産運用事業部 設定 ───────────────────────────────────────
# ドキュメントルート（変更不要）
INVESTMENT_DIVISION_DIR=./ArcoCapital/資産運用事業部
# リスク管理パラメータ
MAX_POSITION_PCT=0.10    # 1銘柄の最大ポジション（総資産比率）
STOP_LOSS_PCT=0.05       # デフォルトストップロス幅 (-5%)
TAKE_PROFIT_PCT=0.10     # デフォルト利確幅 (+10%)
